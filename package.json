{
  "name": "pikud-alert-monitor",
  "version": "1.0.0",
  "description": "A Node.js application to monitor Israeli emergency alerts using pikud-haoref-api",
  "main": "pikud.js",
  "scripts": {
    "start": "node --no-deprecation pikud.js",
    "test:api": "node scripts/test-api.js",
    "build:data": "node scripts/build-static-data.js",
    "serve:static": "node scripts/serve-static.js",
    "web": "npm run serve:static"
  },
  "dependencies": {
    "pikud-haoref-api": "github:eladnava/pikud-haoref-api"
  },
  "keywords": [
    "pikud-haoref",
    "emergency-alerts",
    "israel",
    "monitoring"
  ],
  "author": "",
  "license": "MIT"
}
